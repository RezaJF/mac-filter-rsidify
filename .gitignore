# Python bytecode
__pycache__/
*.py[cod]
./scripts/__pycache__/*.pyc
*.pyc

# Chunk-specific inputs JSONs generated by generate_manifest.py
# (keep only the generic template mac_filter_rsidify.json)
wdl/*.chunk_*.json
wdl/[0-9]*.chunk_*.json

# Chunk-specific manifest TSVs generated by generate_manifest.py
wdl/*.chunk_*.tsv
wdl/[0-9]*.chunk_*.tsv

# Per-run submission reports
wdl/WDL_SUBMISSION_REPORT_*.md
